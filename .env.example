# =============================================================================
#  KONFIGURASI ENVIRONMENT - MULTI-AGENT SYSTEM (MAS)
#  Seluruh API Key untuk CEO, CTO, dan CISO Agents
# =============================================================================

# ---------------------------------------------------------------------------
#  [SHARED] API Keys - Digunakan oleh semua agent
# ---------------------------------------------------------------------------

# Anthropic Claude API Key (WAJIB - untuk CEO & semua agent berbasis Claude)
# Dapatkan di: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API Key (opsional - untuk agent yang membutuhkan GPT)
# WAJIB untuk Open Alice multi-market trading agent
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google AI / Gemini API Key (opsional)
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
#  [CEO] Claude Swarm Orchestrator
# ---------------------------------------------------------------------------

# Model yang digunakan untuk dekomposisi tugas (default: opus)
CLAUDESWARM_MODEL=opus

# Budget maksimum per sesi dalam USD (default: 5.0)
CLAUDESWARM_BUDGET=5.0

# Jumlah maksimum agen konkuren (default: 4)
CLAUDESWARM_MAX_AGENTS=4

# Maksimum percobaan ulang untuk task gagal (default: 1)
CLAUDESWARM_RETRY=1

# Aktifkan Quality Gate (true/false)
CLAUDESWARM_QUALITY_GATE=true

# ---------------------------------------------------------------------------
#  [CTO OFFICE] JARVIS Automation Platform
# ---------------------------------------------------------------------------

# API Key untuk Exa search (pencarian web AI)
# Dapatkan di: https://dashboard.exa.ai/
EXA_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# API Key untuk PimEyes (reverse face search)
PIMEYES_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Token GitHub untuk akses repositori
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Browser automation settings
BROWSER_HEADLESS=true

# ---------------------------------------------------------------------------
#  [CTO TRADING] Behavioral RL & HyperMamba
# ---------------------------------------------------------------------------

# API Key untuk data pasar (contoh: Alpha Vantage, Yahoo Finance)
MARKET_DATA_API_KEY=xxxxxxxxxxxxxxxx

# Symbol/Instrument default untuk trading
TRADING_SYMBOLS=BTC-USD,ETH-USD,SPY,AAPL,TSLA

# Mode trading (paper = simulasi, live = real)
TRADING_MODE=paper

# Initial capital untuk paper trading (USD)
TRADING_INITIAL_CAPITAL=10000

# Risk parameters
CVAR_ALPHA=0.05
MAX_POSITION_SIZE=0.1

# Weights & Biases API Key (opsional - untuk logging experiment ML)
WANDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
#  [CTO COMMERCE] Agent of Commerce
# ---------------------------------------------------------------------------

# RPC URL untuk Solana blockchain
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Wallet private key untuk transaksi on-chain (JANGAN SHARE!)
SOLANA_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Redis connection untuk message broker
REDIS_URL=redis://redis:6379/0

# Database URL
DATABASE_URL=sqlite+aiosqlite:///data/commerce.db

# ---------------------------------------------------------------------------
#  [CISO SHIELD] AgentShield Security Scanner
# ---------------------------------------------------------------------------

# Direktori yang akan di-scan (pisahkan dengan koma)
SHIELD_SCAN_DIRS=/workspace,/data,/config

# Level keparahan minimum untuk dilaporkan (info, low, medium, high, critical)
SHIELD_MIN_SEVERITY=medium

# Format output (json, html, table)
SHIELD_OUTPUT_FORMAT=json

# ---------------------------------------------------------------------------
#  [CISO ECC] Everything Claude Code - Agent Harness
# ---------------------------------------------------------------------------

# Mode operasi ECC
ECC_MODE=guardian

# Path ke direktori skills
ECC_SKILLS_DIR=/data/skills

# Path ke direktori memori
ECC_MEMORY_DIR=/data/memory

# Policy file untuk agent guardrails
ECC_POLICY_FILE=/config/ecc-policy.yaml

# ---------------------------------------------------------------------------
#  [INFRASTRUCTURE] Docker & Jaringan
# ---------------------------------------------------------------------------

# Nama Docker network
MAS_NETWORK_NAME=mas-net

# Direktori shared workspace (mount ke semua container)
MAS_WORKSPACE_DIR=./workspace

# Direktori data persisten
MAS_DATA_DIR=./data

# Direktori konfigurasi
MAS_CONFIG_DIR=./config

# Timezone
TZ=Asia/Jakarta

# ---------------------------------------------------------------------------
#  [RESOURCE MANAGEMENT] Optimasi untuk hardware terbatas
# ---------------------------------------------------------------------------

# Mode operasi: full, lightweight, minimal
# - full: semua 7 container berjalan
# - lightweight: hanya CEO + 2 CTO aktif (default untuk RAM < 4GB)
# - minimal: hanya CEO + 1 CTO (untuk RAM < 2GB)
MAS_MODE=lightweight

# Batas maksimum memory per container (format: 512m, 1g, 2g)
# Untuk Intel Celeron (RAM 2GB), rekomendasi: 256m per container
MAS_CONTAINER_MEMORY_LIMIT=256m

# CPU limit per container (format: 0.5, 1.0, 2.0)
MAS_CPU_LIMIT=0.5
