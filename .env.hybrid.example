# =============================================================================
#  ENVIRONMENT VARS - HYBRID MODE (VPS Cloud)
#  Template untuk koneksi lokal <-> cloud VPS
#  Copy file ini ke .env dan isi nilai-nilai yang sesuai
# =============================================================================

# ---------------------------------------------------------------------------
#  API KEYS (wajib)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WANDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MARKET_DATA_API_KEY=xxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
#  Koneksi VPS
# ---------------------------------------------------------------------------
SSH_HOST=123.456.789.0           # IP VPS Anda
SSH_USER=root                     # SSH user
SSH_PORT=22                       # SSH port
SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----
xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
-----END OPENSSH PRIVATE KEY-----"

# ---------------------------------------------------------------------------
#  Redis Replication (opsional - sync dengan laptop lokal)
# ---------------------------------------------------------------------------
REDIS_MASTER_HOST=192.168.1.10   # IP laptop lokal
REDIS_MASTER_PORT=6379            # Port Redis lokal

# ---------------------------------------------------------------------------
#  Port Configuration
# ---------------------------------------------------------------------------
HYBRID_REDIS_URL=redis://redis-replica:6379/0
REDIS_PORT=6380
REDIS_CLOUD_PORT=6380
HYBRID_HEALTH_PORT=9090
ALICE_WEB_PORT=47331
ALICE_MCP_PORT=47332
ALICE_UTA_PORT=47333

# ---------------------------------------------------------------------------
#  Trading Defaults
# ---------------------------------------------------------------------------
TRADING_MODE=paper
TRADING_SYMBOLS=BTC-USD,ETH-USD
TRADING_INITIAL_CAPITAL=10000
CVAR_ALPHA=0.05
MAX_POSITION_SIZE=0.1
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
